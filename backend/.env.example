# Database (matches docker-compose.yaml defaults)
DATABASE_URL=postgres://lernpunkt:lernpunkt@localhost:5432/lernpunkt

# Google OAuth — create credentials at https://console.cloud.google.com/
# Set Authorized redirect URI to: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173

# Server port
PORT=3001

# action_pool URL (AI processing service)
ACTION_POOL_URL=http://localhost:8000
